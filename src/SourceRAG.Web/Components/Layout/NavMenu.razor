<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SourceRAG</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-chat-fill-nav-menu" aria-hidden="true"></span> Chat
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="status">
                <span class="bi bi-database-fill-nav-menu" aria-hidden="true"></span> Index Status
            </NavLink>
        </div>
    </nav>

    <AuthorizeView>
        <Authorized>
            <div class="px-3 pt-3 pb-1 text-white-50 small">
                @context.User.Identity?.Name
            </div>
            <div class="nav-item px-3 pb-3">
                <a class="nav-link text-white-50" href="MicrosoftIdentity/Account/SignOut">Sign out</a>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-item px-3 pb-3">
                <a class="nav-link text-white-50" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
